# =============================================================
# Kairós Intelligence v2.7.1 — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o arquivo .env no repositório.
# =============================================================

# --- Evolution Go (Gateway WhatsApp) ---
EVOLUTION_API_KEY=PLACEHOLDER_EVOLUTION_KEY
EVOLUTION_API_URL=http://evolution-go:8080
EVOLUTION_INSTANCE_NAME=kairos-clinica

# --- DeepSeek (LLM Principal — Prometheus + Front-Desk) ---
DEEPSEEK_API_KEY=PLACEHOLDER_DEEPSEEK_KEY
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Google Gemini (OCR, Visão, TTS, Transcrição) ---
GEMINI_API_KEY=PLACEHOLDER_GEMINI_KEY
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash

# --- Google Cloud TTS Journey (Voz) ---
GOOGLE_TTS_API_KEY=PLACEHOLDER_GOOGLE_TTS_KEY
GOOGLE_TTS_VOICE=pt-BR-Journey-F
GOOGLE_TTS_SPEED=1.0

# --- ERP Ademed (Credenciais do sistema da clínica) ---
ADEMED_URL=PLACEHOLDER_ADEMED_URL
ADEMED_USER=PLACEHOLDER_ADEMED_USER
ADEMED_PASS=PLACEHOLDER_ADEMED_PASS

# --- Redis (Buffer + Cache) ---
REDIS_URL=redis://redis:6379/0
REDIS_BUFFER_SECONDS=8

# --- PostgreSQL (Governança + Paperclip) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=kairos
POSTGRES_USER=kairos
POSTGRES_PASSWORD=PLACEHOLDER_POSTGRES_PASSWORD

# --- Paperclip (Control Plane / Governança Multi-Tenant) ---
PAPERCLIP_AUTH_SECRET=PLACEHOLDER_PAPERCLIP_SECRET
PAPERCLIP_PUBLIC_URL=http://localhost:3000

# --- Neo4j (GraphRAG — Grafo de Conhecimento) ---
NEO4J_PASSWORD=PLACEHOLDER_NEO4J_PASSWORD
NEO4J_URI=bolt://neo4j:7687

# --- ChromaDB (GraphRAG — Vetores de Embedding) ---
CHROMA_AUTH_TOKEN=PLACEHOLDER_CHROMA_TOKEN
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- MinIO (Armazenamento de Mídia) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=PLACEHOLDER_MINIO_ACCESS
MINIO_SECRET_KEY=PLACEHOLDER_MINIO_SECRET
MINIO_BUCKET=kairos-media

# --- OpenClaw ---
OPENCLAW_CONFIG_PATH=/home/openclaw/.openclaw/openclaw.json
OPENCLAW_GATEWAY_PASSWORD=PLACEHOLDER_OPENCLAW_PASSWORD

# --- Tailscale (VPN) ---
TAILSCALE_AUTH_KEY=PLACEHOLDER_TAILSCALE_KEY

# --- Monitoramento ---
UPTIME_ROBOT_API_KEY=PLACEHOLDER_UPTIME_KEY

# --- WhatsApp do Gestor (Prometheus) ---
GESTOR_WHATSAPP=PLACEHOLDER_GESTOR_PHONE
GESTOR_NOME=PLACEHOLDER_GESTOR_NOME

# --- WhatsApp da Recepcionista ---
RECEPCIONISTA_WHATSAPP=PLACEHOLDER_RECEPCIONISTA_PHONE

# --- Clínica ---
CLINICA_NOME=PLACEHOLDER_CLINICA_NOME
CLINICA_ENDERECO=PLACEHOLDER_CLINICA_ENDERECO
CLINICA_TELEFONE=PLACEHOLDER_CLINICA_TELEFONE
CLINICA_CNPJ=PLACEHOLDER_CLINICA_CNPJ

# --- Backup ---
BACKUP_GITHUB_REPO=Steniogit/kairos-intelligence
BACKUP_CRON="30 4 * * *"

# --- Logs ---
LOG_LEVEL=INFO
LOG_DIR=/home/openclaw/logs
