# =============================================================
# Kairós Intelligence v2.7.1 — Produção (Hostinger VPS)
# =============================================================
# ATENÇÃO: Preencha TODAS as variáveis antes de subir!
# =============================================================

# --- Traefik / Hostinger ---
TRAEFIK_HOST=srv1652132.hstgr.cloud
COMPOSE_PROJECT_NAME=kairos

# --- OpenClaw (Projeto — diferente do pessoal que usa 49844) ---
OPENCLAW_PORT=18789
OPENCLAW_GATEWAY_TOKEN=GERE_UM_TOKEN_SEGURO_AQUI

# --- LLMs ---
DEEPSEEK_API_KEY=SUA_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
GEMINI_API_KEY=SUA_GEMINI_API_KEY

# --- Evolution Go (WhatsApp) ---
EVOLUTION_API_KEY=GERE_UMA_API_KEY_SEGURA

# --- PostgreSQL ---
POSTGRES_DB=kairos
POSTGRES_USER=kairos_user
POSTGRES_PASSWORD=GERE_UMA_SENHA_SEGURA_POSTGRES

# --- Redis ---
REDIS_URL=redis://kairos-redis:6379

# --- Neo4j (GraphRAG) ---
NEO4J_PASSWORD=GERE_UMA_SENHA_SEGURA_NEO4J

# --- ChromaDB (Vetores) ---
CHROMA_AUTH_TOKEN=GERE_UM_TOKEN_SEGURO_CHROMA

# --- Paperclip (Control Plane) ---
PAPERCLIP_AUTH_SECRET=GERE_UM_SECRET_SEGURO_PAPERCLIP
PAPERCLIP_URL=http://kairos-paperclip:3000

# --- MinIO (Armazenamento de Mídia) ---
MINIO_ACCESS_KEY=kairos_minio_admin
MINIO_SECRET_KEY=GERE_UMA_SENHA_SEGURA_MINIO
MINIO_ENDPOINT=http://kairos-minio:9000
MINIO_BUCKET=kairos-media

# --- Ademed (ERP) ---
ADEMED_URL=https://app.ademed.com.br
ADEMED_USER=SEU_USUARIO_ADEMED
ADEMED_PASS=SUA_SENHA_ADEMED

# --- WhatsApp do Gestor (Prometheus) ---
GESTOR_WHATSAPP=5561996705162

# --- Timezone ---
TZ=America/Sao_Paulo
