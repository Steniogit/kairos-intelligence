{
  // OpenClaw Config — Kairós Intelligence Ecosystem
  // Formato: JSON5 (suporta comentários e trailing commas)

  "gateway": {
    "mode": "local"
  },

  // ─── Plugins ────────────────────────────────────────
  "plugins": {
    "allow": ["diagnostics-otel", "telemetry"],
    "entries": {
      "diagnostics-otel": {
        "enabled": true
      },
      "telemetry": {
        "enabled": true
      }
    }
  },

  // ─── Observabilidade (OpenTelemetry) ────────────────
  "diagnostics": {
    "enabled": true,
    "otel": {
      "enabled": true,
      "endpoint": "http://kairos-paperclip:3000/api/otel",
      "protocol": "http/protobuf",
      "serviceName": "kairos-openclaw",
      "traces": true,
      "metrics": true,
      "logs": true,
      "sampleRate": 1.0
    }
  },

  // ─── Guardrails (Limites do Agente) ─────────────────
  // Definidos no runtime do agente, não na telemetria global.
  // Cada agente (Front-Desk, Manager, Sincronizador)
  // herda de seu SOUL.md + configs abaixo.
  "agentDefaults": {
    "maxToolCalls": 10,
    "timeoutSeconds": 120
  }
}